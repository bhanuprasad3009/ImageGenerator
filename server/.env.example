# Server Environment Configuration Example

# Network
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database
MONGO_URI=mongodb://localhost:27017/aetherart

# Security
JWT_SECRET=aetherart_secret_key_123456

# AI Generation Engine (Optional keys - if omitted, Pollinations AI free fallback is used)
STABILITY_KEY=your_stability_ai_api_key_here
OPENAI_KEY=your_openai_api_key_here

# Payment Integration (Optional keys - if omitted, AetherArt runs in simulated checkout mode)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PRO_PRICE_ID=your_pro_plan_stripe_price_id
STRIPE_PREMIUM_PRICE_ID=your_premium_plan_stripe_price_id
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
